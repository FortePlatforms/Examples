# Your Forte project ID. On Forte this is injected into your website automatically; set it
# here only for local development. next.config.ts inlines it into the browser bundle (Next.js
# does that automatically only for NEXT_PUBLIC_* names).
FORTE_PROJECT_ID=

# The URL of your backend service. Locally this is the backend dev server; in production
# set it to your service's URL (e.g. https://<your-service>.tryforte.dev).
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080
