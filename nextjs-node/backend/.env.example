# FORTE_API_TOKEN and FORTE_PROJECT_ID are injected automatically when this app runs
# as a Forte *service*. Set them here only for local development — get them from the
# Forte dashboard (Project -> API tokens).
FORTE_API_TOKEN=
FORTE_PROJECT_ID=

# The origin of your frontend website, used for CORS. Locally this is the Next.js dev
# server; in production set it to your website's URL (e.g. https://<id>.sites.tryforte.dev).
FRONTEND_ORIGIN=http://localhost:3000

# Port the service listens on locally. Forte provides PORT in production.
# Leave 8080 for `forte proxy` (the local gateway stand-in); it forwards to this port.
PORT=8081

# Postgres connection string. In production this is set for you — connect a Forte managed
# database to this service and choose DATABASE_URL as the variable name. Locally, point it at
# your own Postgres (the README has a one-line docker run).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
