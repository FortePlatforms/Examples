# Your Forte project ID. On Forte this is injected into your website automatically; set it here
# only for local development. Vite exposes only prefixed variables to the browser bundle, so
# vite.config.ts adds FORTE_ alongside VITE_. Copy this file to .env.local and fill it in.
FORTE_PROJECT_ID=

# The URL of your backend service. Locally this is the backend dev server; in production
# set it to your service's URL (e.g. https://<your-service>.tryforte.dev).
VITE_BACKEND_URL=http://localhost:8080
