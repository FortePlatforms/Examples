# Your Forte project ID. On Forte this is injected into your website automatically as
# VITE_FORTE_PROJECT_ID; set it here only for local development. Vite only exposes variables
# prefixed with VITE_ to the browser bundle. Copy this file to .env.local and fill it in.
VITE_FORTE_PROJECT_ID=

# The URL of your backend service. Locally this is the backend dev server; in production
# set it to your service's URL (e.g. https://<your-service>.tryforte.dev).
VITE_BACKEND_URL=http://localhost:8080
